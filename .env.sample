# ============================================================
# Pile Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider ---
# "ollama"        = Ollama via OpenAI-compatible /v1 endpoint (default, recommended)
# "openai"        = LM Studio or any OpenAI-compatible endpoint
# "ollama-native" = Ollama native API (single-agent only, no workflows)
LLM_PROVIDER=ollama

# --- Ollama (when LLM_PROVIDER=ollama or ollama-native) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_ID=qwen3.5:9b

# --- OpenAI-compatible (when LLM_PROVIDER=openai) ---
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_MODEL=qwen3.5:9b
# OPENAI_API_KEY=lm-studio

# --- Jira ---
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=YOUR_KEY

# --- Git Repositories (optional) ---
# Option A: Simple — comma-separated local paths (public or already-cloned repos)
# GIT_REPOS=/path/to/repo1,/path/to/repo2

# Option B: Advanced — JSON array for repos with credentials (private repos)
# GIT_REPOS_JSON=[{"path":"/path/to/repo1","url":"https://github.com/org/repo1.git","token":"ghp_xxxx"},{"path":"/path/to/repo2","url":"https://github.com/org/repo2.git","username":"user","password":"pass"}]

# Credential formats supported:
#   token              — standalone API token (GitHub PAT, GitLab PAT, etc.)
#   username + password — basic auth (also works with API tokens as password)

# --- Agent Limits (tune per model capability) ---
AGENT_MAX_ITERATIONS=5               # Max LLM roundtrips per agent turn
AGENT_MAX_FUNCTION_CALLS=15          # Max tool calls per agent turn

# --- Memory / RAG ---
MEMORY_ENABLED=true
MEMORY_STORE_PATH=~/.pile/chromadb
EMBEDDING_MODEL_ID=nomic-embed-text          # Ollama: nomic-embed-text / OpenAI: text-embedding-ada-002

# --- Browser (Playwright + Firefox, optional) ---
BROWSER_ENABLED=true
BROWSER_PROFILE_PATH=~/.pile/browser

# Browser auto-login credentials (optional — fill to enable auto-login)
# BROWSER_JIRA_EMAIL=your@email.com
# BROWSER_JIRA_PASSWORD=your-password
# BROWSER_GITHUB_USERNAME=your-username
# BROWSER_GITHUB_PASSWORD=your-password
# BROWSER_GITLAB_USERNAME=your-username
# BROWSER_GITLAB_PASSWORD=your-password

# --- UI ---
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000
